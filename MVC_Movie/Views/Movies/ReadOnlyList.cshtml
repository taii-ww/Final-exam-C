@model IEnumerable<MVC_Movie.Models.Movie>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Movies</h1>
<br />

<table id="movies" class="table table-borderless">
    <thead>
        <tr class="success">
            <th>Movie List</th>
            <th>Genre</th>
            <th>Available</th>
            <th>Rent</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>

@section scripts{
    <script>
        $(document).ready(function () {
            $("#movies").DataTable({
                ajax: {
                    url: "/api/movies",
                    dataSrc: ""
                },
                columns: [
                    {
                        data: "name", render: function (data, type, movie) {
                            return "<a href='/movies/details/" + movie.id + "'>" + movie.name + "</a>";
                        } },
                    { data: "genre.name" },
                    { data: "numberAvailable" },
                    {
                        data: "id",
                        render: function (data) {
                            return "<a href='/rentals/book/" + data + "' class='btn btn-primary btn-sm'>Rent</a>";
                        }
                    }
                ]
            });
        });
    </script>
}    